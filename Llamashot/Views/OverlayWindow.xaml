<Window x:Class="Llamashot.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#60FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <!-- Layer 1: Screenshot background -->
        <Image x:Name="ScreenshotImage" Stretch="None"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />

        <!-- Layer 2: Dimming overlay -->
        <Canvas x:Name="DimmingCanvas" IsHitTestVisible="False">
            <Path x:Name="DimmingPath" Fill="#80000000" />
        </Canvas>

        <!-- Layer 3: Selection + Annotations -->
        <Canvas x:Name="MainCanvas"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                Background="Transparent">

            <!-- Selection border -->
            <Border x:Name="SelectionBorder"
                    BorderBrush="#2196F3"
                    BorderThickness="1.5"
                    Visibility="Collapsed"
                    IsHitTestVisible="False" />

            <!-- Dimension label -->
            <Border x:Name="DimensionBorder"
                    Background="#CC333333"
                    CornerRadius="3"
                    Padding="6,2"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="DimensionText"
                           Foreground="White"
                           FontSize="12"
                           FontFamily="Segoe UI" />
            </Border>
        </Canvas>

        <!-- Layer 4: Drawing canvas (clipped to selection) -->
        <Canvas x:Name="DrawingCanvas"
                MouseLeftButtonDown="Drawing_MouseLeftButtonDown"
                MouseMove="Drawing_MouseMove"
                MouseLeftButtonUp="Drawing_MouseLeftButtonUp"
                Background="Transparent"
                Visibility="Collapsed" />

        <!-- Layer 5: Resize handles -->
        <Canvas x:Name="HandleCanvas" IsHitTestVisible="True" Visibility="Collapsed" />

        <!-- Layer 6: Toolbars -->
        <Canvas x:Name="ToolbarCanvas" Visibility="Collapsed">
            <!-- Vertical drawing tools toolbar (right side) -->
            <Border x:Name="DrawingToolbar"
                    Background="#F0333333"
                    CornerRadius="4"
                    Padding="3"
                    BorderBrush="#555"
                    BorderThickness="1">
                <StackPanel x:Name="DrawingToolsPanel" Orientation="Vertical">
                    <Button x:Name="BtnPen" ToolTip="Pen (P)" Click="Tool_Click" Tag="Pen" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Path Stroke="White" StrokeThickness="1.5" Data="M2,16 Q5,8 10,6 Q14,4 16,2" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnLine" ToolTip="Line (L)" Click="Tool_Click" Tag="Line" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Line X1="2" Y1="16" X2="16" Y2="2" Stroke="White" StrokeThickness="1.5" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnArrow" ToolTip="Arrow (A)" Click="Tool_Click" Tag="Arrow" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Line X1="2" Y1="16" X2="14" Y2="4" Stroke="White" StrokeThickness="1.5" />
                                <Path Stroke="White" StrokeThickness="1.5" Data="M10,2 L16,2 L16,8" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnRect" ToolTip="Rectangle (R)" Click="Tool_Click" Tag="Rectangle" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Rectangle Canvas.Left="2" Canvas.Top="3" Width="14" Height="12"
                                           Stroke="White" StrokeThickness="1.5" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnEllipse" ToolTip="Ellipse (E)" Click="Tool_Click" Tag="Ellipse" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Ellipse Canvas.Left="1" Canvas.Top="2" Width="16" Height="14"
                                         Stroke="White" StrokeThickness="1.5" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnText" ToolTip="Text (T)" Click="Tool_Click" Tag="Text" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <TextBlock Text="A" Foreground="White" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" Width="18" TextAlignment="Center" />
                        </Border>
                    </Button>
                    <Button x:Name="BtnMarker" ToolTip="Marker (M)" Click="Tool_Click" Tag="Marker" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Rectangle Canvas.Left="2" Canvas.Top="6" Width="14" Height="6"
                                           Fill="#80FFFF00" Stroke="White" StrokeThickness="0.5" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnBlur" ToolTip="Blur (B)" Click="Tool_Click" Tag="Blur" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="14" Height="14"
                                           Fill="#40888888" Stroke="White" StrokeThickness="1" StrokeDashArray="2,1" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Separator Background="#555" Margin="2,4" />
                    <!-- Color picker button -->
                    <Button x:Name="BtnColor" ToolTip="Color (C)" Click="Color_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Ellipse x:Name="ColorIndicator" Width="18" Height="18"
                                     Fill="Red" Stroke="White" StrokeThickness="1.5" />
                        </Border>
                    </Button>
                    <!-- Thickness buttons -->
                    <Button x:Name="BtnThicknessUp" ToolTip="Thicker (Ctrl++)" Click="ThicknessUp_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <TextBlock Text="+" Foreground="White" FontSize="16" FontWeight="Bold"
                                       Width="18" TextAlignment="Center" />
                        </Border>
                    </Button>
                    <Button x:Name="BtnThicknessDown" ToolTip="Thinner (Ctrl+-)" Click="ThicknessDown_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <TextBlock Text="-" Foreground="White" FontSize="16" FontWeight="Bold"
                                       Width="18" TextAlignment="Center" />
                        </Border>
                    </Button>
                    <Separator Background="#555" Margin="2,4" />
                    <Button x:Name="BtnUndo" ToolTip="Undo (Ctrl+Z)" Click="Undo_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Path Stroke="White" StrokeThickness="1.5" Data="M6,4 L2,8 L6,12" />
                                <Path Stroke="White" StrokeThickness="1.5" Data="M2,8 L12,8 A4,4 0 0,1 12,16 L8,16" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnRedo" ToolTip="Redo (Ctrl+Y)" Click="Redo_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Path Stroke="White" StrokeThickness="1.5" Data="M12,4 L16,8 L12,12" />
                                <Path Stroke="White" StrokeThickness="1.5" Data="M16,8 L6,8 A4,4 0 0,0 6,16 L10,16" />
                            </Canvas>
                        </Border>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Horizontal action toolbar (bottom) -->
            <Border x:Name="ActionToolbar"
                    Background="#F0333333"
                    CornerRadius="4"
                    Padding="3"
                    BorderBrush="#555"
                    BorderThickness="1">
                <StackPanel x:Name="ActionToolsPanel" Orientation="Horizontal">
                    <Button x:Name="BtnSave" ToolTip="Save (Ctrl+S)" Click="Save_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Path Fill="White" Data="M2,2 L14,2 L16,4 L16,16 L2,16 Z M5,2 L5,7 L13,7 L13,2 M5,10 L13,10 M5,12 L13,12 M5,14 L11,14" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnCopy" ToolTip="Copy (Ctrl+C)" Click="Copy_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Rectangle Canvas.Left="4" Canvas.Top="4" Width="12" Height="12"
                                           Stroke="White" StrokeThickness="1.5" />
                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="12" Height="12"
                                           Stroke="White" StrokeThickness="1.5" Fill="#333" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnPrint" ToolTip="Print" Click="Print_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Path Fill="White" Data="M3,12 L3,6 L15,6 L15,12 M1,8 L1,14 L4,14 L4,11 L14,11 L14,14 L17,14 L17,8 Z" />
                                <Rectangle Canvas.Left="5" Canvas.Top="2" Width="8" Height="5" Stroke="White" StrokeThickness="1" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Separator Background="#555" Margin="4,2" />
                    <Button x:Name="BtnPin" ToolTip="Pin on screen" Click="Pin_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Path Fill="White" Data="M9,16 L9,11 M5,11 L13,11 M7,3 L7,8 L5,11 L13,11 L11,8 L11,3 Z M6,2 L12,2 L12,3 L6,3 Z" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Separator Background="#555" Margin="4,2" />
                    <Button x:Name="BtnClose" ToolTip="Close (Escape)" Click="Close_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="6">
                            <Canvas Width="18" Height="18">
                                <Line X1="3" Y1="3" X2="15" Y2="15" Stroke="#FF6666" StrokeThickness="2" />
                                <Line X1="15" Y1="3" X2="3" Y2="15" Stroke="#FF6666" StrokeThickness="2" />
                            </Canvas>
                        </Border>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Color palette popup -->
        <Canvas x:Name="ColorPaletteCanvas" Visibility="Collapsed">
            <Border x:Name="ColorPalette"
                    Background="#F0333333"
                    CornerRadius="4"
                    Padding="6"
                    BorderBrush="#555"
                    BorderThickness="1">
                <WrapPanel x:Name="ColorSwatches" Width="132" />
            </Border>
        </Canvas>
    </Grid>
</Window>
