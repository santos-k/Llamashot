<Window x:Class="Llamashot.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        PreviewKeyDown="Window_KeyDown"
        PreviewKeyUp="Window_KeyUp"
        MouseWheel="Window_MouseWheel"
        Focusable="True">
    <Window.Resources>
        <Style x:Key="TBtn" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Width="30" Height="30">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Flexible button style for toolbar items with text labels -->
        <Style x:Key="TBtnFlex" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="6,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Image x:Name="ScreenshotImage" Stretch="None"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />

        <Canvas x:Name="DimmingCanvas" IsHitTestVisible="False">
            <Path x:Name="DimmingPath" Fill="#80000000" />
        </Canvas>

        <Canvas x:Name="MainCanvas"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                Background="Transparent">
            <Border x:Name="SelectionBorder"
                    BorderBrush="#2196F3" BorderThickness="2"
                    Visibility="Collapsed" IsHitTestVisible="False" />
            <!-- Dashed selection for OCR mode -->
            <Rectangle x:Name="OcrDashBorder"
                       Stroke="#26C6DA" StrokeThickness="2"
                       StrokeDashArray="4 2" Fill="#1026C6DA"
                       Visibility="Collapsed" IsHitTestVisible="False" />
            <Border x:Name="DimensionBorder"
                    Background="#DD000000" CornerRadius="3" Padding="8,3"
                    Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock x:Name="DimensionText"
                           Foreground="White" FontSize="12" FontFamily="Segoe UI" />
            </Border>
        </Canvas>

        <Canvas x:Name="DrawingCanvas"
                MouseLeftButtonDown="Drawing_MouseLeftButtonDown"
                MouseMove="Drawing_MouseMove"
                MouseLeftButtonUp="Drawing_MouseLeftButtonUp"
                Background="Transparent"
                Visibility="Collapsed" />

        <Canvas x:Name="HandleCanvas" IsHitTestVisible="False" Visibility="Collapsed" />

        <!-- Snipping Toolbar (top center, shown before region selection) -->
        <Canvas x:Name="SnippingToolbarCanvas" Visibility="Collapsed">
            <Border x:Name="SnippingToolbar"
                    Background="#FF111111" CornerRadius="8" Padding="4"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.7" ShadowDepth="3" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <!-- Screenshot mode -->
                    <Button x:Name="BtnModeScreenshot" ToolTip="Screenshot (1)" Click="ModeScreenshot_Click" Style="{StaticResource TBtnFlex}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="14" Height="10" RadiusX="2" RadiusY="2"
                                           Stroke="#64B5F6" StrokeThickness="1.5" />
                                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="6" Height="6"
                                         Stroke="#64B5F6" StrokeThickness="1.5" />
                            </Canvas>
                            <TextBlock x:Name="LblScreenshot" Text="Screenshot" Foreground="#64B5F6" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!-- Video mode -->
                    <Button x:Name="BtnModeVideo" ToolTip="Video (2)" Click="ModeVideo_Click" Style="{StaticResource TBtnFlex}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="10" Height="10" RadiusX="2" RadiusY="2"
                                           Stroke="#888" StrokeThickness="1.5" />
                                <Path Data="M12,5 L16,3 L16,13 L12,11 Z" Fill="#888" />
                            </Canvas>
                            <TextBlock x:Name="LblVideo" Text="Video" Foreground="#888" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!-- Scroll mode -->
                    <Button x:Name="BtnModeScroll" ToolTip="Scroll Capture (4)" Click="ModeScroll_Click" Style="{StaticResource TBtnFlex}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="2" Canvas.Top="0" Width="12" Height="14" Stroke="#FFA726" StrokeThickness="1.5" RadiusX="1" RadiusY="1" />
                                <Line X1="5" Y1="4" X2="11" Y2="4" Stroke="#FFA726" StrokeThickness="1" />
                                <Line X1="5" Y1="7" X2="11" Y2="7" Stroke="#FFA726" StrokeThickness="1" />
                                <Line X1="5" Y1="10" X2="11" Y2="10" Stroke="#FFA726" StrokeThickness="1" />
                                <Path Data="M6,13 L8,16 L10,13" Stroke="#FFA726" StrokeThickness="1.5" Fill="Transparent" />
                            </Canvas>
                            <TextBlock x:Name="LblScroll" Text="Scroll" Foreground="#FFA726" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!-- Scroll auto/manual toggle (only visible in scroll mode) -->
                    <Button x:Name="BtnScrollToggle" ToolTip="Toggle Auto/Manual" Click="ScrollToggle_Click"
                            Style="{StaticResource TBtnFlex}" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LblScrollToggle" Text="Auto" Foreground="#FFA726" FontSize="11"
                                       VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="#333" Margin="3,5" />
                    <!-- OCR mode -->
                    <Button x:Name="BtnModeOcr" ToolTip="Text Extract (3)" Click="ModeOcr_Click" Style="{StaticResource TBtnFlex}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="16" Height="16">
                                <Ellipse Canvas.Left="1" Canvas.Top="0" Width="10" Height="10"
                                         Stroke="#26C6DA" StrokeThickness="1.5" />
                                <TextBlock Canvas.Left="3.5" Canvas.Top="-1" Text="T" Foreground="#26C6DA"
                                           FontSize="8" FontWeight="Bold" />
                                <Line X1="9.5" Y1="9" X2="14" Y2="13.5" Stroke="#00ACC1" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                            <TextBlock x:Name="LblOcr" Text="OCR" Foreground="#26C6DA" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!-- Delay dropdown -->
                    <Button x:Name="BtnDelay" ToolTip="Delay timer" Click="Delay_Click" Style="{StaticResource TBtnFlex}">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="14" Height="14">
                                <Ellipse Width="14" Height="14" Stroke="#888" StrokeThickness="1.5" />
                                <Line X1="7" Y1="3" X2="7" Y2="7" Stroke="#888" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="7" Y1="7" X2="10" Y2="9" Stroke="#888" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                            <TextBlock x:Name="DelayLabel" Text="No delay" Foreground="#AAA" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                            <Path Data="M0,0 L4,4 L8,0" Stroke="#888" StrokeThickness="1.5" Margin="4,6,0,0" Width="8" Height="5" />
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="#333" Margin="3,5" />
                    <!-- Close -->
                    <Button x:Name="BtnSnippingClose" ToolTip="Close (Esc)" Click="Close_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="14" Height="14">
                            <Line X1="2" Y1="2" X2="12" Y2="12" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="12" Y1="2" X2="2" Y2="12" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                </StackPanel>
            </Border>
            <!-- Mode underline indicator -->
            <Border x:Name="ModeIndicator" Height="3" Width="22" CornerRadius="1.5" Background="#2196F3"
                    IsHitTestVisible="False" />
        </Canvas>

        <!-- Delay dropdown popup -->
        <Canvas x:Name="DelayPopupCanvas" Visibility="Collapsed">
            <Border x:Name="DelayPopup"
                    Background="#FF111111" CornerRadius="6" Padding="4"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.5" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel x:Name="DelayOptions" />
            </Border>
        </Canvas>

        <!-- Toolbars -->
        <Canvas x:Name="ToolbarCanvas" Visibility="Collapsed">
            <!-- Drawing tools (right side) - adaptive 1 or 2 columns -->
            <Border x:Name="DrawingToolbar"
                    Background="#FF111111" CornerRadius="6" Padding="3"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.6" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel x:Name="DrawingToolsPanel">
                    <!-- Tool buttons in a WrapPanel (width controls columns) -->
                    <WrapPanel x:Name="ToolWrapPanel" Width="32">
                        <!-- Pencil: orange body, light tip, brown graphite -->
                        <Button x:Name="BtnPen" ToolTip="Pencil (P)" Click="Tool_Click" Tag="Pen" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Path Fill="#FFA726" Data="M12.5,0.5 L15.5,3.5 L5,14 L1,15 L2,11 Z" />
                                <Path Fill="#FFE082" Data="M12.5,0.5 L15.5,3.5 L14,5 L11,2 Z" />
                                <Path Fill="#5D4037" Data="M1,15 L2,11 L5,14 Z" />
                            </Canvas>
                        </Button>
                        <!-- Line: blue diagonal with endpoint dots -->
                        <Button x:Name="BtnLine" ToolTip="Line (L)" Click="Tool_Click" Tag="Line" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Line X1="2" Y1="14" X2="14" Y2="2" Stroke="#64B5F6" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Ellipse Canvas.Left="0.5" Canvas.Top="12.5" Width="3" Height="3" Fill="#90CAF9" />
                                <Ellipse Canvas.Left="12.5" Canvas.Top="0.5" Width="3" Height="3" Fill="#90CAF9" />
                            </Canvas>
                        </Button>
                        <!-- Arrow: cyan with arrowhead -->
                        <Button x:Name="BtnArrow" ToolTip="Arrow (A)" Click="Tool_Click" Tag="Arrow" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Line X1="1" Y1="15" X2="12" Y2="4" Stroke="#26C6DA" StrokeThickness="2" StrokeStartLineCap="Round" />
                                <Path Fill="#26C6DA" Data="M15,1 L9,4 L12,7 Z" />
                            </Canvas>
                        </Button>
                        <!-- Rectangle: blue outlined -->
                        <Button x:Name="BtnRect" ToolTip="Rectangle (R)" Click="Tool_Click" Tag="Rectangle" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="1" Canvas.Top="2" Width="14" Height="12"
                                           Stroke="#42A5F5" StrokeThickness="2" />
                            </Canvas>
                        </Button>
                        <!-- Ellipse: purple outlined -->
                        <Button x:Name="BtnEllipse" ToolTip="Ellipse (E)" Click="Tool_Click" Tag="Ellipse" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Ellipse Canvas.Left="1" Canvas.Top="2" Width="14" Height="12"
                                         Stroke="#AB47BC" StrokeThickness="2" />
                            </Canvas>
                        </Button>
                        <!-- Text: yellow "A" -->
                        <Button x:Name="BtnText" ToolTip="Text (T)" Click="Tool_Click" Tag="Text" Style="{StaticResource TBtn}">
                            <TextBlock Text="A" Foreground="#FFCA28" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <!-- Marker: yellow highlighter pen -->
                        <Button x:Name="BtnMarker" ToolTip="Marker (M)" Click="Tool_Click" Tag="Marker" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="4" Canvas.Top="1" Width="8" Height="11"
                                           Fill="#FFEE58" RadiusX="2" RadiusY="2" />
                                <Rectangle Canvas.Left="5" Canvas.Top="12" Width="6" Height="3"
                                           Fill="#F9A825" />
                            </Canvas>
                        </Button>
                        <!-- Blur: mosaic pixel grid -->
                        <Button x:Name="BtnBlur" ToolTip="Blur (B)" Click="Tool_Click" Tag="Blur" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="0" Canvas.Top="0" Width="5" Height="5" Fill="#78909C" />
                                <Rectangle Canvas.Left="5.5" Canvas.Top="0" Width="5" Height="5" Fill="#546E7A" />
                                <Rectangle Canvas.Left="11" Canvas.Top="0" Width="5" Height="5" Fill="#78909C" />
                                <Rectangle Canvas.Left="0" Canvas.Top="5.5" Width="5" Height="5" Fill="#546E7A" />
                                <Rectangle Canvas.Left="5.5" Canvas.Top="5.5" Width="5" Height="5" Fill="#90A4AE" />
                                <Rectangle Canvas.Left="11" Canvas.Top="5.5" Width="5" Height="5" Fill="#546E7A" />
                                <Rectangle Canvas.Left="0" Canvas.Top="11" Width="5" Height="5" Fill="#78909C" />
                                <Rectangle Canvas.Left="5.5" Canvas.Top="11" Width="5" Height="5" Fill="#546E7A" />
                                <Rectangle Canvas.Left="11" Canvas.Top="11" Width="5" Height="5" Fill="#90A4AE" />
                            </Canvas>
                        </Button>
                        <!-- Check: green circle with checkmark -->
                        <Button x:Name="BtnCheck" ToolTip="Check mark (K)" Click="Tool_Click" Tag="Check" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Ellipse Width="16" Height="16" Stroke="#4CAF50" StrokeThickness="1.5" Fill="#304CAF50" />
                                <Path Stroke="#4CAF50" StrokeThickness="2.5" Data="M4,8.5 L7,11.5 L12,4.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                            </Canvas>
                        </Button>
                        <!-- Cross: red circle with X -->
                        <Button x:Name="BtnCross" ToolTip="Cross mark (D)" Click="Tool_Click" Tag="CrossMark" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Ellipse Width="16" Height="16" Stroke="#F44336" StrokeThickness="1.5" Fill="#30F44336" />
                                <Line X1="4.5" Y1="4.5" X2="11.5" Y2="11.5" Stroke="#F44336" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="11.5" Y1="4.5" X2="4.5" Y2="11.5" Stroke="#F44336" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Button>
                        <!-- Eraser: white body with pink rubber tip -->
                        <Button x:Name="BtnObjectEraser" ToolTip="Eraser (G)" Click="Tool_Click" Tag="Eraser" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Path Fill="#B0BEC5" Data="M14,4 L8,10 L5,13 L2,13 L2,10 L6,6 L12,0 Z" />
                                <Path Fill="#EF5350" Data="M2,10 L5,13 L2,13 Z" />
                                <Line X1="1" Y1="15" X2="15" Y2="15" Stroke="#607D8B" StrokeThickness="1.5" />
                            </Canvas>
                        </Button>
                        <!-- Undo: orange curved arrow -->
                        <Button x:Name="BtnEraser" ToolTip="Undo (X)" Click="Eraser_Click" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="#FFA726" StrokeThickness="2" Data="M6,4 L2,8 L6,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                <Path Stroke="#FFA726" StrokeThickness="2" Data="M2,8 L11,8 A4,4 0 0,1 11,15 L8,15" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Button>
                        <!-- Move: light blue crosshair arrows -->
                        <Button x:Name="BtnMove" ToolTip="Move (V)" Click="Move_Click" Style="{StaticResource TBtn}">
                            <Canvas Width="16" Height="16">
                                <Line X1="8" Y1="1" X2="8" Y2="15" Stroke="#42A5F5" StrokeThickness="1.5" />
                                <Line X1="1" Y1="8" X2="15" Y2="8" Stroke="#42A5F5" StrokeThickness="1.5" />
                                <Path Fill="#42A5F5" Data="M8,0 L5,3 L11,3 Z" />
                                <Path Fill="#42A5F5" Data="M8,16 L5,13 L11,13 Z" />
                                <Path Fill="#42A5F5" Data="M0,8 L3,5 L3,11 Z" />
                                <Path Fill="#42A5F5" Data="M16,8 L13,5 L13,11 Z" />
                            </Canvas>
                        </Button>
                    </WrapPanel>
                    <Rectangle Height="1" Fill="#333" Margin="2,3" />
                    <!-- Color + Thickness row -->
                    <WrapPanel x:Name="BottomToolsPanel" Width="32">
                        <Button x:Name="BtnColor" ToolTip="Color (C)" Click="Color_Click" Style="{StaticResource TBtn}">
                            <Ellipse x:Name="ColorIndicator" Width="18" Height="18"
                                     Fill="Yellow" Stroke="White" StrokeThickness="2" />
                        </Button>
                        <!-- Thickness dropdown button -->
                        <Button x:Name="BtnThickness" ToolTip="Thickness (W)" Click="Thickness_Click" Style="{StaticResource TBtn}">
                            <Grid Width="20" Height="20">
                                <Ellipse Width="20" Height="20" Fill="#444" Stroke="#666" StrokeThickness="1" />
                                <TextBlock x:Name="ThicknessLabel" Text="3" Foreground="White"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Action toolbar (bottom) -->
            <Border x:Name="ActionToolbar"
                    Background="#FF111111" CornerRadius="6" Padding="3"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.6" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel x:Name="ActionToolsPanel" Orientation="Horizontal">
                    <!-- Save - blue floppy -->
                    <Button x:Name="BtnSave" ToolTip="Save (Ctrl+S)" Click="Save_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Path Fill="#42A5F5" Data="M1,1 L12,1 L15,4 L15,15 L1,15 Z" />
                            <Rectangle Canvas.Left="4" Canvas.Top="1" Width="6" Height="5" Fill="#1E88E5" />
                            <Rectangle Canvas.Left="4" Canvas.Top="9" Width="8" Height="5" Fill="White" RadiusX="1" RadiusY="1" />
                        </Canvas>
                    </Button>
                    <!-- Copy - green -->
                    <Button x:Name="BtnCopy" ToolTip="Copy (Ctrl+C)" Click="Copy_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="11" Height="11"
                                       Stroke="#66BB6A" StrokeThickness="1.5" />
                            <Rectangle Canvas.Left="1" Canvas.Top="1" Width="11" Height="11"
                                       Stroke="#66BB6A" StrokeThickness="1.5" Fill="#111" />
                            <Path Fill="#66BB6A" Data="M4,7 L6,7 L6,4 L4,4 Z" />
                        </Canvas>
                    </Button>
                    <!-- History - orange clock -->
                    <Button x:Name="BtnHistory" ToolTip="History (H)" Click="History_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Ellipse Canvas.Left="1" Canvas.Top="1" Width="14" Height="14"
                                     Stroke="#FFA726" StrokeThickness="1.5" />
                            <Line X1="8" Y1="4" X2="8" Y2="8" Stroke="#FFA726" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="8" Y1="8" X2="11" Y2="10" Stroke="#FFA726" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                    <!-- Pin - purple -->
                    <Button x:Name="BtnPin" ToolTip="Pin on screen (F)" Click="Pin_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Path Fill="#AB47BC" Data="M8,15 L8,11 M5,11 L11,11 M6,3 L6,8 L5,11 L11,11 L10,8 L10,3 Z" />
                            <Rectangle Canvas.Left="5" Canvas.Top="1" Width="6" Height="2" Fill="#CE93D8" RadiusX="1" RadiusY="1" />
                            <Line X1="8" Y1="11" X2="8" Y2="15" Stroke="#AB47BC" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                    <!-- Record - red -->
                    <Button x:Name="BtnRecord" ToolTip="Record region (Ctrl+R)" Click="Record_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Ellipse Canvas.Left="1" Canvas.Top="1" Width="14" Height="14"
                                     Stroke="#F44336" StrokeThickness="2" />
                            <Ellipse Canvas.Left="4" Canvas.Top="4" Width="8" Height="8"
                                     Fill="#F44336" />
                        </Canvas>
                    </Button>
                    <!-- OCR - cyan magnifying glass with T -->
                    <Button x:Name="BtnOcr" ToolTip="Extract Text (O)" Click="Ocr_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Ellipse Canvas.Left="1" Canvas.Top="0" Width="11" Height="11"
                                     Stroke="#26C6DA" StrokeThickness="2" />
                            <TextBlock Canvas.Left="3.5" Canvas.Top="-1" Text="T" Foreground="#26C6DA"
                                       FontSize="9" FontWeight="Bold" />
                            <Line X1="10.5" Y1="10" X2="15" Y2="14.5" Stroke="#00ACC1" StrokeThickness="2.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                    <Rectangle Width="1" Fill="#333" Margin="2,4" />
                    <!-- Close - red X -->
                    <Button x:Name="BtnClose" ToolTip="Close (Esc)" Click="Close_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="16" Height="16">
                            <Line X1="3" Y1="3" X2="13" Y2="13" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="13" Y1="3" X2="3" Y2="13" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Video pre-start toolbar (shown instead of annotation tools for video mode) -->
        <Canvas x:Name="VideoToolbarCanvas" Visibility="Collapsed">
            <Border x:Name="VideoToolbar"
                    Background="#EE111111" CornerRadius="8" Padding="6,4"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.6" ShadowDepth="3" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <!-- Start button -->
                    <Button x:Name="BtnVideoStart" Click="VideoStart_Click" Cursor="Hand" Focusable="False" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#2196F3" CornerRadius="14" Padding="14,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Stroke="White" StrokeThickness="2" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Start" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#42A5F5" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E88E5" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Timer -->
                    <TextBlock x:Name="VideoTimer" Text="00:00:00" Foreground="White" FontSize="15"
                               FontWeight="SemiBold" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Rectangle Width="1" Fill="#444" Margin="4,4" />
                    <!-- Mic toggle -->
                    <Button x:Name="BtnVideoMic" Click="VideoMic_Click" Width="28" Height="28" Margin="4,0,2,0"
                            Cursor="Hand" ToolTip="Toggle microphone (M)"
                            Background="Transparent" BorderBrush="Transparent" Focusable="False">
                        <Canvas Width="16" Height="16">
                            <Rectangle x:Name="VideoMicBody" Canvas.Left="5.5" Canvas.Top="1" Width="5" Height="9"
                                       RadiusX="2.5" RadiusY="2.5" Fill="#666" />
                            <Path x:Name="VideoMicArc" Data="M3,8 A5,5 0 0,0 13,8" Stroke="#666" StrokeThickness="1.5"
                                  Canvas.Top="2" Fill="Transparent" />
                            <Line x:Name="VideoMicStand" X1="8" Y1="13" X2="8" Y2="15" Stroke="#666" StrokeThickness="1.5" />
                            <Line x:Name="VideoMicSlash" X1="2" Y1="14" X2="14" Y2="2" Stroke="#EF5350"
                                  StrokeThickness="2" Visibility="Visible" />
                        </Canvas>
                    </Button>
                    <!-- System audio toggle -->
                    <Button x:Name="BtnVideoSysAudio" Click="VideoSysAudio_Click" Width="28" Height="28" Margin="0,0,2,0"
                            Cursor="Hand" ToolTip="Toggle system audio (S)"
                            Background="Transparent" BorderBrush="Transparent" Focusable="False">
                        <Canvas Width="16" Height="16">
                            <Path x:Name="VideoSpeakerBody" Data="M2,6 L5,6 L9,3 L9,13 L5,10 L2,10 Z" Fill="#666" />
                            <Path x:Name="VideoSpeakerWave1" Data="M11,6 A3,3 0 0,1 11,10" Stroke="#666"
                                  StrokeThickness="1.5" Fill="Transparent" />
                            <Path x:Name="VideoSpeakerWave2" Data="M12.5,4 A5,5 0 0,1 12.5,12" Stroke="#666"
                                  StrokeThickness="1.5" Fill="Transparent" />
                            <Line x:Name="VideoSpeakerSlash" X1="2" Y1="14" X2="14" Y2="2" Stroke="#EF5350"
                                  StrokeThickness="2" Visibility="Visible" />
                        </Canvas>
                    </Button>
                    <Rectangle Width="1" Fill="#444" Margin="4,4" />
                    <!-- Close -->
                    <Button Click="Close_Click" Style="{StaticResource TBtn}">
                        <Canvas Width="14" Height="14">
                            <Line X1="2" Y1="2" X2="12" Y2="12" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="12" Y1="2" X2="2" Y2="12" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Color palette popup -->
        <Canvas x:Name="ColorPaletteCanvas" Visibility="Collapsed">
            <Border x:Name="ColorPalette"
                    Background="#FF111111" CornerRadius="6" Padding="6"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.6" ShadowDepth="2" />
                </Border.Effect>
                <WrapPanel x:Name="ColorSwatches" Width="156" />
            </Border>
        </Canvas>

        <!-- Thickness popup -->
        <Canvas x:Name="ThicknessPopupCanvas" Visibility="Collapsed">
            <Border x:Name="ThicknessPopup"
                    Background="#FF111111" CornerRadius="6" Padding="4"
                    BorderBrush="#333" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.6" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel x:Name="ThicknessOptions" />
            </Border>
        </Canvas>
    </Grid>
</Window>
