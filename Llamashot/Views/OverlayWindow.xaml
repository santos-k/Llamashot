<Window x:Class="Llamashot.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        PreviewKeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        Focusable="True">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#70FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <!-- Layer 1: Screenshot background -->
        <Image x:Name="ScreenshotImage" Stretch="None"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />

        <!-- Layer 2: Dimming overlay -->
        <Canvas x:Name="DimmingCanvas" IsHitTestVisible="False">
            <Path x:Name="DimmingPath" Fill="#80000000" />
        </Canvas>

        <!-- Layer 3: Selection -->
        <Canvas x:Name="MainCanvas"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                Background="Transparent">

            <!-- Selection border -->
            <Border x:Name="SelectionBorder"
                    BorderBrush="#2196F3"
                    BorderThickness="2"
                    Visibility="Collapsed"
                    IsHitTestVisible="False" />

            <!-- Dimension label -->
            <Border x:Name="DimensionBorder"
                    Background="#DD333333"
                    CornerRadius="3"
                    Padding="8,3"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="DimensionText"
                           Foreground="White"
                           FontSize="13"
                           FontFamily="Segoe UI" />
            </Border>
        </Canvas>

        <!-- Layer 4: Drawing canvas (clipped to selection) -->
        <Canvas x:Name="DrawingCanvas"
                MouseLeftButtonDown="Drawing_MouseLeftButtonDown"
                MouseMove="Drawing_MouseMove"
                MouseLeftButtonUp="Drawing_MouseLeftButtonUp"
                Background="Transparent"
                Visibility="Collapsed" />

        <!-- Layer 5: Resize handles (visual only, hit testing done in MainCanvas) -->
        <Canvas x:Name="HandleCanvas" IsHitTestVisible="False" Visibility="Collapsed" />

        <!-- Layer 6: Toolbars -->
        <Canvas x:Name="ToolbarCanvas" Visibility="Collapsed">
            <!-- Vertical drawing tools toolbar (right side) -->
            <Border x:Name="DrawingToolbar"
                    Background="#EE2D2D30"
                    CornerRadius="6"
                    Padding="4"
                    BorderBrush="#555"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.4" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel x:Name="DrawingToolsPanel" Orientation="Vertical">
                    <Button x:Name="BtnPen" ToolTip="Pen (P)" Click="Tool_Click" Tag="Pen" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Path Stroke="#E0E0E0" StrokeThickness="2" Data="M2,20 Q6,10 12,7 Q16,5 20,2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnLine" ToolTip="Line (L)" Click="Tool_Click" Tag="Line" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Line X1="2" Y1="20" X2="20" Y2="2" Stroke="#E0E0E0" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnArrow" ToolTip="Arrow (A)" Click="Tool_Click" Tag="Arrow" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Line X1="2" Y1="20" X2="16" Y2="5" Stroke="#E0E0E0" StrokeThickness="2" StrokeStartLineCap="Round" />
                                <Path Fill="#E0E0E0" Data="M20,2 L12,5 L16,9 Z" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnRect" ToolTip="Rectangle (R)" Click="Tool_Click" Tag="Rectangle" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Rectangle Canvas.Left="2" Canvas.Top="4" Width="18" Height="14"
                                           Stroke="#E0E0E0" StrokeThickness="2" RadiusX="1" RadiusY="1" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnEllipse" ToolTip="Ellipse (E)" Click="Tool_Click" Tag="Ellipse" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Ellipse Canvas.Left="1" Canvas.Top="3" Width="20" Height="16"
                                         Stroke="#E0E0E0" StrokeThickness="2" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnText" ToolTip="Text (T)" Click="Tool_Click" Tag="Text" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <TextBlock Text="A" Foreground="#E0E0E0" FontSize="17" FontWeight="Bold"
                                       HorizontalAlignment="Center" Width="22" TextAlignment="Center" />
                        </Border>
                    </Button>
                    <Button x:Name="BtnMarker" ToolTip="Marker (M)" Click="Tool_Click" Tag="Marker" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Rectangle Canvas.Left="1" Canvas.Top="7" Width="20" Height="8"
                                           Fill="#90FFFF00" RadiusX="2" RadiusY="2" />
                                <Line X1="4" Y1="11" X2="18" Y2="11" Stroke="#E0E0E0" StrokeThickness="1" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnBlur" ToolTip="Blur (B)" Click="Tool_Click" Tag="Blur" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="18" Height="18"
                                           Fill="#50888888" Stroke="#E0E0E0" StrokeThickness="1.5" StrokeDashArray="3,2" RadiusX="2" RadiusY="2" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnEraser" ToolTip="Eraser (X)" Click="Eraser_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Path Stroke="#E0E0E0" StrokeThickness="2" Data="M4,18 L14,8 L18,12 L8,22" StrokeLineJoin="Round" />
                                <Path Fill="#E0E0E0" Data="M14,8 L18,4 L22,8 L18,12 Z" />
                                <Line X1="2" Y1="21" X2="12" Y2="21" Stroke="#E0E0E0" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Separator Background="#555" Margin="3,6" />
                    <!-- Color picker button -->
                    <Button x:Name="BtnColor" ToolTip="Color (C)" Click="Color_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Ellipse x:Name="ColorIndicator" Width="22" Height="22"
                                     Fill="Red" Stroke="White" StrokeThickness="2" />
                        </Border>
                    </Button>
                    <!-- Thickness buttons -->
                    <Button x:Name="BtnThicknessUp" ToolTip="Thicker (Ctrl++)" Click="ThicknessUp_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <TextBlock Text="+" Foreground="#E0E0E0" FontSize="20" FontWeight="Bold"
                                       Width="22" TextAlignment="Center" />
                        </Border>
                    </Button>
                    <Button x:Name="BtnThicknessDown" ToolTip="Thinner (Ctrl+-)" Click="ThicknessDown_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <TextBlock Text="-" Foreground="#E0E0E0" FontSize="20" FontWeight="Bold"
                                       Width="22" TextAlignment="Center" />
                        </Border>
                    </Button>
                    <Separator Background="#555" Margin="3,6" />
                    <Button x:Name="BtnUndo" ToolTip="Undo (Ctrl+Z)" Click="Undo_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Path Stroke="#E0E0E0" StrokeThickness="2" Data="M7,5 L2,10 L7,15" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                <Path Stroke="#E0E0E0" StrokeThickness="2" Data="M2,10 L14,10 A5,5 0 0,1 14,20 L10,20" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Button x:Name="BtnRedo" ToolTip="Redo (Ctrl+Y)" Click="Redo_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="7">
                            <Canvas Width="22" Height="22">
                                <Path Stroke="#E0E0E0" StrokeThickness="2" Data="M15,5 L20,10 L15,15" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                <Path Stroke="#E0E0E0" StrokeThickness="2" Data="M20,10 L8,10 A5,5 0 0,0 8,20 L12,20" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Border>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Horizontal action toolbar (bottom) -->
            <Border x:Name="ActionToolbar"
                    Background="#EE2D2D30"
                    CornerRadius="6"
                    Padding="4"
                    BorderBrush="#555"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.4" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel x:Name="ActionToolsPanel" Orientation="Horizontal">
                    <Button x:Name="BtnSave" ToolTip="Save (Ctrl+S)" Click="Save_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <Canvas Width="20" Height="20">
                                    <Path Fill="#64B5F6" Data="M2,1 L15,1 L19,5 L19,19 L2,19 Z" />
                                    <Rectangle Canvas.Left="6" Canvas.Top="1" Width="7" Height="7" Fill="#2D2D30" />
                                    <Rectangle Canvas.Left="5" Canvas.Top="11" Width="10" Height="7" Fill="#E0E0E0" RadiusX="1" RadiusY="1" />
                                </Canvas>
                                <TextBlock Text="Save" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button x:Name="BtnCopy" ToolTip="Copy (Ctrl+C)" Click="Copy_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <Canvas Width="20" Height="20">
                                    <Rectangle Canvas.Left="5" Canvas.Top="5" Width="13" Height="13"
                                               Stroke="#64B5F6" StrokeThickness="2" RadiusX="1" RadiusY="1" />
                                    <Rectangle Canvas.Left="2" Canvas.Top="2" Width="13" Height="13"
                                               Stroke="#E0E0E0" StrokeThickness="2" Fill="#2D2D30" RadiusX="1" RadiusY="1" />
                                </Canvas>
                                <TextBlock Text="Copy" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button x:Name="BtnPrint" ToolTip="Print" Click="Print_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="8,6">
                            <Canvas Width="20" Height="20">
                                <Rectangle Canvas.Left="4" Canvas.Top="1" Width="12" Height="6" Stroke="#E0E0E0" StrokeThickness="1.5" />
                                <Rectangle Canvas.Left="1" Canvas.Top="7" Width="18" Height="8" Fill="#64B5F6" RadiusX="2" RadiusY="2" />
                                <Rectangle Canvas.Left="4" Canvas.Top="12" Width="12" Height="7" Stroke="#E0E0E0" StrokeThickness="1.5" Fill="#2D2D30" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Rectangle Width="1" Fill="#555" Margin="6,4" />
                    <Button x:Name="BtnPin" ToolTip="Pin on screen" Click="Pin_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="8,6">
                            <Canvas Width="20" Height="20">
                                <Path Fill="#64B5F6" Data="M10,18 L10,13 M6,13 L14,13 M8,4 L8,10 L6,13 L14,13 L12,10 L12,4 Z" />
                                <Rectangle Canvas.Left="7" Canvas.Top="2" Width="6" Height="2" Fill="#E0E0E0" RadiusX="1" RadiusY="1" />
                                <Line X1="10" Y1="13" X2="10" Y2="18" Stroke="#E0E0E0" StrokeThickness="2" />
                            </Canvas>
                        </Border>
                    </Button>
                    <Rectangle Width="1" Fill="#555" Margin="6,4" />
                    <Button x:Name="BtnClose" ToolTip="Close (Escape)" Click="Close_Click" Style="{x:Null}">
                        <Border Background="Transparent" Padding="8,6">
                            <Canvas Width="20" Height="20">
                                <Line X1="4" Y1="4" X2="16" Y2="16" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="16" Y1="4" X2="4" Y2="16" Stroke="#EF5350" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Border>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Color palette popup -->
        <Canvas x:Name="ColorPaletteCanvas" Visibility="Collapsed">
            <Border x:Name="ColorPalette"
                    Background="#EE2D2D30"
                    CornerRadius="6"
                    Padding="6"
                    BorderBrush="#555"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.4" ShadowDepth="2" />
                </Border.Effect>
                <WrapPanel x:Name="ColorSwatches" Width="156" />
            </Border>
        </Canvas>
    </Grid>
</Window>
