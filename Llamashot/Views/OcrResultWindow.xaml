<Window x:Class="Llamashot.Views.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Resources/icon32.png"
        Title="Llamashot - Extracted Text"
        Width="520" Height="400"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#222" Padding="20,14" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Canvas Width="20" Height="20" Margin="0,0,10,0">
                        <Rectangle Width="20" Height="20" Stroke="#26C6DA" StrokeThickness="2" RadiusX="3" RadiusY="3" />
                        <TextBlock Canvas.Left="5" Canvas.Top="1" Text="T" Foreground="#26C6DA"
                                   FontSize="12" FontWeight="Bold" />
                        <Line X1="5" Y1="17" X2="15" Y2="17" Stroke="#00ACC1" StrokeThickness="2" />
                    </Canvas>
                    <TextBlock Text="Extracted Text" FontSize="17" FontWeight="SemiBold"
                               Foreground="#EEE" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="TxtCharCount" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#777" FontSize="12" />
            </Grid>
        </Border>

        <!-- Text content -->
        <Border Grid.Row="1" Margin="16,12,16,0" Background="#252528" CornerRadius="6"
                BorderBrush="#333" BorderThickness="1" Padding="2">
            <TextBox x:Name="ResultText"
                     Background="Transparent" Foreground="#EEE"
                     FontSize="13" FontFamily="Consolas, Segoe UI"
                     BorderThickness="0"
                     Padding="10,8" TextWrapping="Wrap"
                     AcceptsReturn="True" IsReadOnly="False"
                     VerticalScrollBarVisibility="Auto"
                     SelectionBrush="#42A5F5"
                     CaretBrush="#42A5F5" />
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#222" Padding="16,10" Margin="0,12,0,0"
                BorderBrush="#333" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Select All" Width="80" Height="30" Click="SelectAll_Click"
                            Background="#333" Foreground="#CCC" BorderBrush="#444"
                            FontSize="12" Cursor="Hand" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Copy All" Width="90" Height="30" Click="CopyAll_Click"
                            Background="#42A5F5" Foreground="White" BorderBrush="#1E88E5"
                            FontWeight="SemiBold" FontSize="12" Cursor="Hand" />
                    <Button Content="Close" Width="80" Height="30" Margin="10,0,0,0" Click="Close_Click"
                            Background="#333" Foreground="#CCC" BorderBrush="#444"
                            FontSize="12" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
