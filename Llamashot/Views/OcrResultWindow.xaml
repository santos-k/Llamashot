<Window x:Class="Llamashot.Views.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Llamashot - Extracted Text"
        Width="500" Height="380"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Extracted Text" FontSize="16" FontWeight="SemiBold"
                   Foreground="#2196F3" Margin="0,0,0,10" />

        <TextBox x:Name="ResultText" Grid.Row="1"
                 Background="#2A2A2A" Foreground="#EEE"
                 FontSize="13" FontFamily="Segoe UI"
                 BorderBrush="#444" BorderThickness="1"
                 Padding="8" TextWrapping="Wrap"
                 AcceptsReturn="True" IsReadOnly="False"
                 VerticalScrollBarVisibility="Auto"
                 SelectionBrush="#2196F3" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copy All" Width="90" Height="30" Click="CopyAll_Click"
                    Background="#2196F3" Foreground="White" BorderBrush="#1976D2" FontWeight="SemiBold" />
            <Button Content="Close" Width="80" Height="30" Margin="10,0,0,0" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
