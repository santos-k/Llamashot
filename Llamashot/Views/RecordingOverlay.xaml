<Window x:Class="Llamashot.Views.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="260" Height="50"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#EE111111" CornerRadius="8" Padding="12,6"
            BorderBrush="#333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="3" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Recording dot (blinks) -->
            <Ellipse x:Name="RecDot" Width="12" Height="12" Fill="#F44336" Margin="0,0,8,0"
                     VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.2" Duration="0:0:0.6"
                                                 AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Timer -->
            <TextBlock x:Name="TxtTimer" Grid.Column="1" Text="00:00"
                       Foreground="White" FontSize="16" FontWeight="SemiBold" FontFamily="Consolas"
                       VerticalAlignment="Center" Margin="0,0,8,0" />

            <!-- Max time hint -->
            <TextBlock x:Name="TxtMax" Grid.Column="2" Text="/ 02:00"
                       Foreground="#666" FontSize="11" VerticalAlignment="Center" />

            <!-- Pause/Resume -->
            <Button x:Name="BtnPause" Grid.Column="3" Click="Pause_Click"
                    Width="28" Height="28" Margin="8,0,4,0" Cursor="Hand"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Rectangle x:Name="PauseIcon1" Canvas.Left="2" Width="4" Height="14" Fill="White" />
                    <Rectangle x:Name="PauseIcon2" Canvas.Left="8" Width="4" Height="14" Fill="White" />
                </Canvas>
            </Button>

            <!-- Stop -->
            <Button x:Name="BtnStop" Grid.Column="4" Click="Stop_Click"
                    Width="28" Height="28" Cursor="Hand"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Rectangle Width="14" Height="14" Fill="#F44336" RadiusX="2" RadiusY="2" />
                </Canvas>
            </Button>
        </Grid>
    </Border>
</Window>
