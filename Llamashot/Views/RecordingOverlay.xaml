<Window x:Class="Llamashot.Views.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="460" Height="50"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="#EE111111" CornerRadius="8" Padding="12,6"
            BorderBrush="#333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="3" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Recording dot (blinks) -->
            <Ellipse x:Name="RecDot" Width="12" Height="12" Fill="#F44336" Margin="0,0,8,0"
                     VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.2" Duration="0:0:0.6"
                                                 AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Timer -->
            <TextBlock x:Name="TxtTimer" Grid.Column="1" Text="00:00"
                       Foreground="White" FontSize="16" FontWeight="SemiBold" FontFamily="Consolas"
                       VerticalAlignment="Center" Margin="0,0,6,0" />

            <!-- Separator -->
            <Rectangle Grid.Column="2" Width="1" Fill="#444" Margin="4,4" />

            <!-- Mic toggle -->
            <Button x:Name="BtnMic" Grid.Column="3" Click="Mic_Click"
                    Width="28" Height="28" Margin="4,0,2,0" Cursor="Hand" ToolTip="Toggle microphone (M)"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="16" Height="16">
                    <Rectangle x:Name="MicBody" Canvas.Left="5.5" Canvas.Top="1" Width="5" Height="9"
                               RadiusX="2.5" RadiusY="2.5" Fill="#666" />
                    <Path x:Name="MicArc" Data="M3,8 A5,5 0 0,0 13,8" Stroke="#666" StrokeThickness="1.5"
                          Canvas.Top="2" Fill="Transparent" />
                    <Line x:Name="MicStand" X1="8" Y1="13" X2="8" Y2="15" Stroke="#666" StrokeThickness="1.5" />
                    <Line x:Name="MicSlash" X1="2" Y1="14" X2="14" Y2="2" Stroke="#EF5350"
                          StrokeThickness="2" Visibility="Visible" />
                </Canvas>
            </Button>

            <!-- System audio toggle -->
            <Button x:Name="BtnSystemAudio" Grid.Column="4" Click="SystemAudio_Click"
                    Width="28" Height="28" Margin="0,0,2,0" Cursor="Hand" ToolTip="Toggle system audio (S)"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="16" Height="16">
                    <Path x:Name="SpeakerBody" Data="M2,6 L5,6 L9,3 L9,13 L5,10 L2,10 Z" Fill="#666" />
                    <Path x:Name="SpeakerWave1" Data="M11,6 A3,3 0 0,1 11,10" Stroke="#666"
                          StrokeThickness="1.5" Fill="Transparent" />
                    <Path x:Name="SpeakerWave2" Data="M12.5,4 A5,5 0 0,1 12.5,12" Stroke="#666"
                          StrokeThickness="1.5" Fill="Transparent" />
                    <Line x:Name="SpeakerSlash" X1="2" Y1="14" X2="14" Y2="2" Stroke="#EF5350"
                          StrokeThickness="2" Visibility="Visible" />
                </Canvas>
            </Button>

            <!-- Audio status text -->
            <TextBlock x:Name="TxtAudioStatus" Grid.Column="5" Text="" Foreground="#666" FontSize="10"
                       VerticalAlignment="Center" Margin="2,0,4,0" MaxWidth="60" TextTrimming="CharacterEllipsis" />

            <!-- Separator -->
            <Rectangle Grid.Column="6" Width="1" Fill="#444" Margin="4,4" />

            <!-- Annotation tools -->
            <Button x:Name="BtnPen" Grid.Column="7" Click="AnnotationTool_Click" Tag="Pen"
                    Width="28" Height="28" Margin="2,0" Cursor="Hand" ToolTip="Pen (P)"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Path Fill="#FFA726" Data="M11,0.5 L13.5,3 L4.5,12 L1,13 L2,9.5 Z" />
                </Canvas>
            </Button>
            <Button x:Name="BtnArrow" Grid.Column="8" Click="AnnotationTool_Click" Tag="Arrow"
                    Width="28" Height="28" Margin="0,0,2,0" Cursor="Hand" ToolTip="Arrow (A)"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Line X1="1" Y1="13" X2="11" Y2="3" Stroke="#FFA726" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <Path Fill="#FFA726" Data="M8,1 L13,1 L13,6" />
                </Canvas>
            </Button>
            <Button x:Name="BtnRect" Grid.Column="9" Click="AnnotationTool_Click" Tag="Rectangle"
                    Width="28" Height="28" Margin="0,0,2,0" Cursor="Hand" ToolTip="Rectangle (R)"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Rectangle Canvas.Left="1" Canvas.Top="2" Width="12" Height="10"
                               Stroke="#FFA726" StrokeThickness="2" />
                </Canvas>
            </Button>
            <Button x:Name="BtnClearAnnotations" Grid.Column="10" Click="ClearAnnotations_Click"
                    Width="28" Height="28" Margin="0,0,2,0" Cursor="Hand" ToolTip="Clear drawings (C)"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Line X1="3" Y1="3" X2="11" Y2="11" Stroke="#EF5350" StrokeThickness="2" />
                    <Line X1="11" Y1="3" X2="3" Y2="11" Stroke="#EF5350" StrokeThickness="2" />
                </Canvas>
            </Button>

            <!-- Separator -->
            <StackPanel Grid.Column="11" Orientation="Horizontal">
                <Rectangle Width="1" Fill="#444" Margin="4,4" />

                <!-- Pause/Resume -->
                <Button x:Name="BtnPause" Click="Pause_Click"
                        Width="28" Height="28" Margin="4,0,2,0" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent" Focusable="False">
                    <Grid Width="14" Height="14">
                        <Canvas x:Name="PauseIcon" Visibility="Visible">
                            <Rectangle Canvas.Left="2" Width="4" Height="14" Fill="White" />
                            <Rectangle Canvas.Left="8" Width="4" Height="14" Fill="White" />
                        </Canvas>
                        <Canvas x:Name="PlayIcon" Visibility="Collapsed">
                            <Path Fill="#4CAF50" Data="M2,0 L14,7 L2,14 Z" />
                        </Canvas>
                    </Grid>
                </Button>

                <!-- Stop -->
                <Button x:Name="BtnStop" Click="Stop_Click"
                        Width="28" Height="28" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent" Focusable="False">
                    <Canvas Width="14" Height="14">
                        <Rectangle Width="14" Height="14" Fill="#F44336" RadiusX="2" RadiusY="2" />
                    </Canvas>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
