<Window x:Class="Llamashot.Views.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="310" Height="50"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#EE111111" CornerRadius="8" Padding="12,6"
            BorderBrush="#333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="3" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Recording dot (blinks) -->
            <Ellipse x:Name="RecDot" Width="12" Height="12" Fill="#F44336" Margin="0,0,8,0"
                     VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.2" Duration="0:0:0.6"
                                                 AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Timer -->
            <TextBlock x:Name="TxtTimer" Grid.Column="1" Text="00:00"
                       Foreground="White" FontSize="16" FontWeight="SemiBold" FontFamily="Consolas"
                       VerticalAlignment="Center" Margin="0,0,8,0" />

            <!-- Audio status -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TxtAudioStatus" Text="" Foreground="#666" FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Audio toggle -->
            <Button x:Name="BtnAudio" Grid.Column="3" Click="Audio_Click"
                    Width="28" Height="28" Margin="4,0" Cursor="Hand" ToolTip="Toggle audio recording"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas x:Name="AudioIcon" Width="16" Height="16">
                    <!-- Mic icon -->
                    <Rectangle x:Name="MicBody" Canvas.Left="5.5" Canvas.Top="1" Width="5" Height="9"
                               RadiusX="2.5" RadiusY="2.5" Fill="#666" />
                    <Path x:Name="MicArc" Data="M3,8 A5,5 0 0,0 13,8" Stroke="#666" StrokeThickness="1.5"
                          Canvas.Top="2" Fill="Transparent" />
                    <Line x:Name="MicStand" X1="8" Y1="13" X2="8" Y2="15" Stroke="#666" StrokeThickness="1.5" />
                    <!-- Mute slash (shown when muted) -->
                    <Line x:Name="MicSlash" X1="2" Y1="14" X2="14" Y2="2" Stroke="#EF5350"
                          StrokeThickness="2" Visibility="Visible" />
                </Canvas>
            </Button>

            <!-- Pause/Resume -->
            <Button x:Name="BtnPause" Grid.Column="4" Click="Pause_Click"
                    Width="28" Height="28" Margin="0,0,4,0" Cursor="Hand"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Grid Width="14" Height="14">
                    <!-- Pause icon (two bars) -->
                    <Canvas x:Name="PauseIcon" Visibility="Visible">
                        <Rectangle Canvas.Left="2" Width="4" Height="14" Fill="White" />
                        <Rectangle Canvas.Left="8" Width="4" Height="14" Fill="White" />
                    </Canvas>
                    <!-- Play icon (triangle) -->
                    <Canvas x:Name="PlayIcon" Visibility="Collapsed">
                        <Path Fill="#4CAF50" Data="M2,0 L14,7 L2,14 Z" />
                    </Canvas>
                </Grid>
            </Button>

            <!-- Stop -->
            <Button x:Name="BtnStop" Grid.Column="5" Click="Stop_Click"
                    Width="28" Height="28" Cursor="Hand"
                    Background="Transparent" BorderBrush="Transparent" Focusable="False">
                <Canvas Width="14" Height="14">
                    <Rectangle Width="14" Height="14" Fill="#F44336" RadiusX="2" RadiusY="2" />
                </Canvas>
            </Button>
        </Grid>
    </Border>
</Window>
