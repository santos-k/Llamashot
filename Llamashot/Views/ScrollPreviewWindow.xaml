<Window x:Class="Llamashot.Views.ScrollPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Llamashot - Scroll Capture"
        Width="800" Height="700"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1E"
        Icon="/Resources/icon32.png">
    <Window.Resources>
        <Style x:Key="TBtn" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Width="30" Height="30">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="#252528" Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
            <WrapPanel x:Name="ToolWrapPanel" Orientation="Horizontal">
                <!-- Drawing tools -->
                <Button x:Name="BtnPen" Click="Tool_Click" Tag="Pen" Style="{StaticResource TBtn}" ToolTip="Pen">
                    <Canvas Width="14" Height="14">
                        <Path Fill="#FFA726" Data="M11,0.5 L13.5,3 L4.5,12 L1,13 L2,9.5 Z" />
                        <Path Fill="#5D4037" Data="M1,13 L2,9.5 L4.5,12 Z" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnLine" Click="Tool_Click" Tag="Line" Style="{StaticResource TBtn}" ToolTip="Line">
                    <Canvas Width="14" Height="14">
                        <Line X1="2" Y1="12" X2="12" Y2="2" Stroke="#64B5F6" StrokeThickness="2" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnArrow" Click="Tool_Click" Tag="Arrow" Style="{StaticResource TBtn}" ToolTip="Arrow">
                    <Canvas Width="14" Height="14">
                        <Line X1="1" Y1="13" X2="10" Y2="4" Stroke="#26C6DA" StrokeThickness="2" />
                        <Path Fill="#26C6DA" Data="M13,1 L8,4 L11,7 Z" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnRect" Click="Tool_Click" Tag="Rectangle" Style="{StaticResource TBtn}" ToolTip="Rectangle">
                    <Canvas Width="14" Height="14">
                        <Rectangle Canvas.Left="1" Canvas.Top="2" Width="12" Height="10" Stroke="#42A5F5" StrokeThickness="2" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnEllipse" Click="Tool_Click" Tag="Ellipse" Style="{StaticResource TBtn}" ToolTip="Ellipse">
                    <Canvas Width="14" Height="14">
                        <Ellipse Canvas.Left="1" Canvas.Top="2" Width="12" Height="10" Stroke="#AB47BC" StrokeThickness="2" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnText" Click="Tool_Click" Tag="Text" Style="{StaticResource TBtn}" ToolTip="Text">
                    <TextBlock Text="A" Foreground="#FFCA28" FontSize="12" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="BtnMarker" Click="Tool_Click" Tag="Marker" Style="{StaticResource TBtn}" ToolTip="Marker">
                    <Canvas Width="14" Height="14">
                        <Rectangle Canvas.Left="3" Canvas.Top="1" Width="8" Height="10" Fill="#FFEE58" RadiusX="2" RadiusY="2" />
                        <Rectangle Canvas.Left="4" Canvas.Top="11" Width="6" Height="2" Fill="#F9A825" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnBlur" Click="Tool_Click" Tag="Blur" Style="{StaticResource TBtn}" ToolTip="Blur">
                    <Canvas Width="14" Height="14">
                        <Ellipse Width="12" Height="12" Canvas.Left="1" Canvas.Top="1" Fill="#78909C" Opacity="0.6" />
                        <Ellipse Width="6" Height="6" Canvas.Left="4" Canvas.Top="4" Fill="#546E7A" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnCheck" Click="Tool_Click" Tag="Check" Style="{StaticResource TBtn}" ToolTip="Check">
                    <Canvas Width="14" Height="14">
                        <Ellipse Width="14" Height="14" Stroke="#4CAF50" StrokeThickness="1.5" Fill="#304CAF50" />
                        <Path Stroke="#4CAF50" StrokeThickness="2" Data="M3.5,7.5 L6,10 L10.5,4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnCross" Click="Tool_Click" Tag="CrossMark" Style="{StaticResource TBtn}" ToolTip="Cross">
                    <Canvas Width="14" Height="14">
                        <Ellipse Width="14" Height="14" Stroke="#F44336" StrokeThickness="1.5" Fill="#30F44336" />
                        <Line X1="4" Y1="4" X2="10" Y2="10" Stroke="#F44336" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Line X1="10" Y1="4" X2="4" Y2="10" Stroke="#F44336" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnEraser" Click="Tool_Click" Tag="Eraser" Style="{StaticResource TBtn}" ToolTip="Eraser">
                    <Canvas Width="14" Height="14">
                        <Path Fill="#B0BEC5" Data="M12,3 L7,8 L4.5,11 L2,11 L2,8 L5,5 L10,0 Z" />
                        <Path Fill="#EF5350" Data="M2,8 L4.5,11 L2,11 Z" />
                        <Line X1="1" Y1="13" X2="13" Y2="13" Stroke="#607D8B" StrokeThickness="1.5" />
                    </Canvas>
                </Button>

                <Rectangle Width="1" Fill="#444" Margin="4,4" />

                <!-- Undo -->
                <Button x:Name="BtnUndo" Click="Undo_Click" Style="{StaticResource TBtn}" ToolTip="Undo">
                    <Canvas Width="14" Height="14">
                        <Path Stroke="#FFA726" StrokeThickness="2" Data="M5,3 L2,6 L5,9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                        <Path Stroke="#FFA726" StrokeThickness="2" Data="M2,6 L9,6 A3,3 0 0,1 9,12 L7,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Button>
                <Button x:Name="BtnRedo" Click="Redo_Click" Style="{StaticResource TBtn}" ToolTip="Redo">
                    <Canvas Width="14" Height="14">
                        <Path Stroke="#FFA726" StrokeThickness="2" Data="M9,3 L12,6 L9,9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                        <Path Stroke="#FFA726" StrokeThickness="2" Data="M12,6 L5,6 A3,3 0 0,0 5,12 L7,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Button>

                <Rectangle Width="1" Fill="#444" Margin="4,4" />

                <!-- Color -->
                <Button x:Name="BtnColor" Click="Color_Click" Style="{StaticResource TBtn}" ToolTip="Color">
                    <Ellipse x:Name="ColorIndicator" Width="16" Height="16" Fill="Yellow" Stroke="White" StrokeThickness="1.5" />
                </Button>
                <!-- Thickness -->
                <Button x:Name="BtnThickness" Click="Thickness_Click" Style="{StaticResource TBtn}" ToolTip="Thickness">
                    <Grid Width="18" Height="18">
                        <Ellipse Width="18" Height="18" Fill="#444" Stroke="#666" StrokeThickness="1" />
                        <TextBlock x:Name="ThicknessLabel" Text="3" Foreground="White"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Rectangle Width="1" Fill="#444" Margin="4,4" />

                <!-- Crop toggle -->
                <Button x:Name="BtnCrop" Click="Crop_Click" Style="{StaticResource TBtn}" ToolTip="Crop">
                    <Canvas Width="14" Height="14">
                        <Line X1="4" Y1="0" X2="4" Y2="10" Stroke="#66BB6A" StrokeThickness="2" />
                        <Line X1="4" Y1="10" X2="14" Y2="10" Stroke="#66BB6A" StrokeThickness="2" />
                        <Line X1="10" Y1="4" X2="10" Y2="14" Stroke="#66BB6A" StrokeThickness="2" />
                        <Line X1="0" Y1="4" X2="10" Y2="4" Stroke="#66BB6A" StrokeThickness="2" />
                    </Canvas>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Image area with scroll -->
        <ScrollViewer x:Name="ImageScroller" Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#111">
            <Grid x:Name="ImageContainer">
                <Image x:Name="PreviewImage" Stretch="None" />
                <Canvas x:Name="DrawingCanvas" Background="Transparent"
                        MouseLeftButtonDown="Drawing_MouseLeftButtonDown"
                        MouseMove="Drawing_MouseMove"
                        MouseLeftButtonUp="Drawing_MouseLeftButtonUp" />
                <!-- Crop overlay -->
                <Canvas x:Name="CropCanvas" Visibility="Collapsed" Background="Transparent"
                        MouseLeftButtonDown="Crop_MouseDown"
                        MouseMove="Crop_MouseMove"
                        MouseLeftButtonUp="Crop_MouseUp">
                    <Path x:Name="CropDimming" Fill="#88000000" />
                    <Rectangle x:Name="CropRect" Stroke="#66BB6A" StrokeThickness="2" StrokeDashArray="4,2" />
                    <Canvas x:Name="CropHandleCanvas" />
                </Canvas>
            </Grid>
        </ScrollViewer>

        <!-- Color palette popup -->
        <Canvas x:Name="ColorPaletteCanvas" Grid.Row="1" Visibility="Collapsed" IsHitTestVisible="True">
            <Border x:Name="ColorPalette" Background="#EE222222" CornerRadius="6" Padding="6">
                <WrapPanel x:Name="ColorSwatches" Width="140" />
            </Border>
        </Canvas>

        <!-- Thickness popup -->
        <Canvas x:Name="ThicknessPopupCanvas" Grid.Row="1" Visibility="Collapsed" IsHitTestVisible="True">
            <Border x:Name="ThicknessPopup" Background="#EE222222" CornerRadius="6" Padding="6">
                <StackPanel x:Name="ThicknessOptions" />
            </Border>
        </Canvas>

        <!-- Bottom buttons -->
        <Border Grid.Row="2" Background="#252528" Padding="12,8" BorderBrush="#333" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtInfo" Foreground="#777" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Content="Save" Width="80" Height="30" Click="Save_Click"
                        Background="#42A5F5" Foreground="White" BorderBrush="#1E88E5"
                        FontWeight="SemiBold" FontSize="13" Cursor="Hand" Margin="0,0,8,0" />
                <Button Content="Copy" Width="80" Height="30" Click="Copy_Click"
                        Background="#333" Foreground="#CCC" BorderBrush="#444"
                        FontSize="13" Cursor="Hand" Margin="0,0,8,0" />
                <Button Content="Discard" Width="80" Height="30" Click="Discard_Click"
                        Background="#333" Foreground="#EF5350" BorderBrush="#444"
                        FontSize="13" Cursor="Hand" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
