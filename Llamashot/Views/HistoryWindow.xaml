<Window x:Class="Llamashot.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Llamashot - History"
        Width="720" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Screenshot History" FontSize="18" FontWeight="SemiBold"
                   Foreground="#2196F3" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A2A" CornerRadius="4" Margin="4" Padding="4"
                                Cursor="Hand" MouseLeftButtonDown="Item_Click"
                                BorderBrush="#444" BorderThickness="1"
                                ToolTip="{Binding ToolTipText}">
                            <StackPanel Width="150">
                                <Grid>
                                    <Image Source="{Binding ThumbnailPath}" Height="90"
                                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <!-- Type badge -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="2" Padding="4,1" Margin="2">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding TypeColor}" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding TypeText}" Foreground="White"
                                                   FontSize="9" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DateText}" Foreground="#AAA" FontSize="10" />
                                        <TextBlock Text="{Binding SizeText}" Foreground="#777" FontSize="10" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Copy" Click="CopyItem_Click"
                                            Width="40" Height="22" FontSize="10"
                                            Background="#333" Foreground="#DDD" BorderBrush="#555"
                                            VerticalAlignment="Center" Cursor="Hand" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Clear History" Width="100" Height="30" Click="ClearHistory_Click"
                    Background="#D32F2F" Foreground="White" BorderBrush="#B71C1C" />
            <Button Content="Close" Width="80" Height="30" Margin="10,0,0,0" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
