<Window x:Class="Llamashot.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Llamashot - History"
        Width="740" Height="530"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#222" Padding="20,14" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Canvas Width="20" Height="20" Margin="0,0,10,0">
                        <Ellipse Width="20" Height="20" Stroke="#42A5F5" StrokeThickness="2" />
                        <Line X1="10" Y1="5" X2="10" Y2="10" Stroke="#42A5F5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Line X1="10" Y1="10" X2="14" Y2="13" Stroke="#42A5F5" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                    <TextBlock Text="Screenshot History" FontSize="17" FontWeight="SemiBold"
                               Foreground="#EEE" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCount" Foreground="#777" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <CheckBox x:Name="ChkSelectAll" Content="Select All" Foreground="#AAA" FontSize="11"
                              VerticalAlignment="Center" Click="SelectAll_Click" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="12,12,12,0">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#252528" CornerRadius="6" Margin="4" Padding="6"
                                Cursor="Hand" MouseLeftButtonDown="Item_Click"
                                BorderBrush="#333" BorderThickness="1"
                                ToolTip="{Binding ToolTipText}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#42A5F5" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Width="150">
                                <Grid>
                                    <Border Background="#1A1A1E" CornerRadius="4" Padding="2">
                                        <Image Source="{Binding ThumbnailPath}" Height="90"
                                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <!-- Selection checkbox -->
                                    <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Click="ItemCheckbox_Click" Cursor="Hand" />
                                    <!-- Type badge -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            CornerRadius="3" Padding="5,2" Margin="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding TypeColor}" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding TypeText}" Foreground="White"
                                                   FontSize="9" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DateText}" Foreground="#BBB" FontSize="11" />
                                        <TextBlock Text="{Binding SizeText}" Foreground="#666" FontSize="10" />
                                    </StackPanel>
                                    <!-- Copy button -->
                                    <Button Grid.Column="1" Click="CopyItem_Click"
                                            Width="24" Height="24" Cursor="Hand" ToolTip="Copy to clipboard"
                                            Background="#333" BorderBrush="#444" BorderThickness="1" Margin="2,0">
                                        <Canvas Width="12" Height="12">
                                            <Rectangle Canvas.Left="3" Canvas.Top="3" Width="8" Height="8"
                                                       Stroke="#66BB6A" StrokeThickness="1.2" />
                                            <Rectangle Canvas.Left="1" Canvas.Top="1" Width="8" Height="8"
                                                       Stroke="#66BB6A" StrokeThickness="1.2" Fill="#252528" />
                                        </Canvas>
                                    </Button>
                                    <!-- Delete button -->
                                    <Button Grid.Column="2" Click="DeleteItem_Click"
                                            Width="24" Height="24" Cursor="Hand" ToolTip="Delete"
                                            Background="#333" BorderBrush="#444" BorderThickness="1">
                                        <Canvas Width="12" Height="12">
                                            <Line X1="2" Y1="2" X2="10" Y2="10" Stroke="#EF5350" StrokeThickness="1.5" />
                                            <Line X1="10" Y1="2" X2="2" Y2="10" Stroke="#EF5350" StrokeThickness="1.5" />
                                        </Canvas>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock x:Name="TxtEmpty" Grid.Row="1"
                   Text="No screenshots yet" FontSize="14" Foreground="#555"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed" />

        <!-- Footer -->
        <Border Grid.Row="2" Background="#222" Padding="16,10" BorderBrush="#333" BorderThickness="0,1,0,0">
            <Grid>
                <!-- Selection actions (left) -->
                <StackPanel x:Name="SelectionActions" Orientation="Horizontal" HorizontalAlignment="Left"
                            Visibility="Collapsed">
                    <TextBlock x:Name="TxtSelected" Foreground="#42A5F5" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Copy Selected" Height="30" Padding="12,0" Click="CopySelected_Click"
                            Background="#333" Foreground="#66BB6A" BorderBrush="#444"
                            FontSize="12" Cursor="Hand" Margin="0,0,6,0" />
                    <Button Content="Delete Selected" Height="30" Padding="12,0" Click="DeleteSelected_Click"
                            Background="#333" Foreground="#EF5350" BorderBrush="#444"
                            FontSize="12" Cursor="Hand" />
                </StackPanel>
                <!-- Default actions (right) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Clear All" Width="90" Height="30" Click="ClearHistory_Click"
                            Background="#333" Foreground="#EF5350" BorderBrush="#444"
                            FontSize="12" Cursor="Hand" />
                    <Button Content="Close" Width="80" Height="30" Margin="10,0,0,0" Click="Close_Click"
                            Background="#333" Foreground="#CCC" BorderBrush="#444"
                            FontSize="12" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
