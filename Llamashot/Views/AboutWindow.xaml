<Window x:Class="Llamashot.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Llamashot"
        Width="420" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#222" Padding="20,18" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Llamashot" FontSize="28" FontWeight="Bold"
                           Foreground="#42A5F5" HorizontalAlignment="Center" />
                <TextBlock Text="Screenshot, Annotate, Record" FontSize="13"
                           Foreground="#999" HorizontalAlignment="Center" Margin="0,4,0,0" />
                <TextBlock Text="Version 2.6.0" Foreground="#666"
                           HorizontalAlignment="Center" FontSize="11" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16,24,16">
            <StackPanel>
                <!-- Features -->
                <TextBlock Text="Features" Foreground="#42A5F5" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Border Background="#252528" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Region, fullscreen, and delayed capture" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Annotation: pen, line, arrow, rectangle, ellipse, text, marker, blur" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Check and cross stamps for review" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Screen recording to MP4 (max 2 min)" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; OCR text extraction from screenshots" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Screenshot history with thumbnails" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Pin screenshot on top, copy, save" />
                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,2" Text="&#x2022; Customizable shortcuts and settings" />
                    </StackPanel>
                </Border>

                <!-- Hotkeys -->
                <TextBlock Text="Default Hotkeys" Foreground="#42A5F5" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Border Background="#252528" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Foreground="#AAA" FontSize="12" Text="Capture region" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="#42A5F5" FontSize="12" Text="PrintScreen" />
                        <TextBlock Grid.Row="1" Foreground="#AAA" FontSize="12" Text="Fullscreen save" Margin="0,4,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#42A5F5" FontSize="12" Text="Shift+PrintScreen" Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2" Foreground="#AAA" FontSize="12" Text="Fullscreen copy" Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Foreground="#42A5F5" FontSize="12" Text="Ctrl+PrintScreen" Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <!-- Credits -->
                <TextBlock Foreground="#666" FontSize="11"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,4,0,0">
                    <Run Text="Made with " /><Run Text="&#x2764;" Foreground="#EF5350" /><Run Text=" by " />
                    <Run Text="Santosh Kumar" Foreground="#42A5F5" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
