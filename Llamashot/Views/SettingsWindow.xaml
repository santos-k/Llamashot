<Window x:Class="Llamashot.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Llamashot - Settings"
        Width="460" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDD" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDD" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,2,0,8" />
            <Setter Property="Height" Value="28" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,2,0,8" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- General -->
                <TextBlock Text="General" FontSize="16" FontWeight="SemiBold" Foreground="#2196F3" Margin="0,0,0,10" />

                <CheckBox x:Name="ChkAutoStart" Content="Start with Windows" />
                <CheckBox x:Name="ChkCaptureCursor" Content="Capture mouse cursor" />
                <CheckBox x:Name="ChkShowNotifications" Content="Show notifications" />
                <CheckBox x:Name="ChkMinimizeToTray" Content="Minimize to system tray" />

                <Separator Background="#444" Margin="0,12" />

                <!-- Hotkeys -->
                <TextBlock Text="Hotkeys" FontSize="16" FontWeight="SemiBold" Foreground="#2196F3" Margin="0,0,0,10" />

                <TextBlock Text="Capture region:" />
                <TextBox x:Name="TxtCaptureHotkey" IsReadOnly="True" Text="PrintScreen" />

                <TextBlock Text="Fullscreen to file:" />
                <TextBox x:Name="TxtFullscreenSaveHotkey" IsReadOnly="True" Text="Shift+PrintScreen" />

                <TextBlock Text="Fullscreen to clipboard:" />
                <TextBox x:Name="TxtFullscreenClipHotkey" IsReadOnly="True" Text="Ctrl+PrintScreen" />

                <Separator Background="#444" Margin="0,12" />

                <!-- Save Settings -->
                <TextBlock Text="Save" FontSize="16" FontWeight="SemiBold" Foreground="#2196F3" Margin="0,0,0,10" />

                <TextBlock Text="Default format:" />
                <ComboBox x:Name="CmbFormat">
                    <ComboBoxItem Content="PNG" />
                    <ComboBoxItem Content="JPG" />
                    <ComboBoxItem Content="BMP" />
                </ComboBox>

                <TextBlock Text="JPEG quality:" />
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="SldJpegQuality" Width="300" Minimum="10" Maximum="100"
                            Value="90" TickFrequency="10" IsSnapToTickEnabled="False" />
                    <TextBlock x:Name="TxtJpegQuality" Text="90" Margin="10,0,0,0" />
                </StackPanel>

                <TextBlock Text="Save directory:" Margin="0,8,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSaveDir" />
                    <Button Grid.Column="1" Content="Browse" Width="70" Height="28"
                            Margin="4,2,0,8" Click="BrowseDir_Click" />
                </Grid>

                <Separator Background="#444" Margin="0,12" />

                <!-- History -->
                <TextBlock Text="History" FontSize="16" FontWeight="SemiBold" Foreground="#2196F3" Margin="0,0,0,10" />
                <CheckBox x:Name="ChkSaveHistory" Content="Save screenshot history" />
                <TextBlock Text="Max history items:" />
                <TextBox x:Name="TxtMaxHistory" Width="80" HorizontalAlignment="Left" />
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="90" Height="32" Click="Save_Click"
                    Background="#2196F3" Foreground="White" BorderBrush="#1976D2" FontWeight="SemiBold" />
            <Button Content="Cancel" Width="90" Height="32" Margin="10,0,0,0" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
