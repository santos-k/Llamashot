<Window x:Class="Llamashot.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Llamashot - Settings"
        Width="500" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1E">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#CCC" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#42A5F5" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCC" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="#252528" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <!-- Hotkey input box style -->
        <Style TargetType="TextBox" x:Key="HotkeyBox">
            <Setter Property="Background" Value="#1A1A1E" />
            <Setter Property="Foreground" Value="#EEE" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,16,20,0">
            <StackPanel>

                <!-- General -->
                <TextBlock Text="General" Style="{StaticResource SectionTitle}" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="ChkAutoStart" Content="Start with Windows" />
                        <CheckBox x:Name="ChkCaptureCursor" Content="Capture mouse cursor" />
                        <CheckBox x:Name="ChkShowNotifications" Content="Show notifications" />
                        <CheckBox x:Name="ChkMinimizeToTray" Content="Minimize to system tray" />
                    </StackPanel>
                </Border>

                <!-- Hotkeys -->
                <TextBlock Text="Hotkeys" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="Click a field, then press your desired key combination" Foreground="#777" FontSize="11" Margin="0,0,0,6" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Capture region" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtCaptureHotkey" Grid.Column="1" Style="{StaticResource HotkeyBox}"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" />
                            <Button Grid.Column="2" Content="Reset" Width="50" Height="26" Margin="6,0,0,0"
                                    Click="ResetHotkey_Click" Tag="CaptureHotkey" FontSize="11"
                                    Background="#333" Foreground="#AAA" BorderBrush="#444" Cursor="Hand" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fullscreen save" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtFullscreenSaveHotkey" Grid.Column="1" Style="{StaticResource HotkeyBox}"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" />
                            <Button Grid.Column="2" Content="Reset" Width="50" Height="26" Margin="6,0,0,0"
                                    Click="ResetHotkey_Click" Tag="FullscreenSaveHotkey" FontSize="11"
                                    Background="#333" Foreground="#AAA" BorderBrush="#444" Cursor="Hand" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fullscreen copy" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtFullscreenClipHotkey" Grid.Column="1" Style="{StaticResource HotkeyBox}"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus" />
                            <Button Grid.Column="2" Content="Reset" Width="50" Height="26" Margin="6,0,0,0"
                                    Click="ResetHotkey_Click" Tag="FullscreenClipHotkey" FontSize="11"
                                    Background="#333" Foreground="#AAA" BorderBrush="#444" Cursor="Hand" />
                        </Grid>
                        <!-- Duplicate warning -->
                        <TextBlock x:Name="TxtHotkeyWarning" Foreground="#EF5350" FontSize="11"
                                   Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Tool Shortcuts -->
                <TextBlock Text="Tool Shortcuts" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="Click a field, then press your desired key or combination" Foreground="#777" FontSize="11" Margin="0,0,0,6" />
                <Border Style="{StaticResource Card}">
                    <StackPanel x:Name="ToolShortcutsPanel" />
                </Border>

                <!-- Save Settings -->
                <TextBlock Text="Output" Style="{StaticResource SectionTitle}" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Default format" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <ComboBox x:Name="CmbFormat" Grid.Column="1" Height="28">
                                <ComboBoxItem Content="PNG" />
                                <ComboBoxItem Content="JPG" />
                                <ComboBoxItem Content="BMP" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="JPEG quality" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <Slider x:Name="SldJpegQuality" Grid.Column="1" Minimum="10" Maximum="100"
                                    Value="90" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtJpegQuality" Grid.Column="2" Text="90" Foreground="#AAA"
                                       FontSize="13" Margin="8,0,0,0" Width="24" VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save directory" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtSaveDir" Grid.Column="1" Height="28" Padding="6,4"
                                     Background="#1A1A1E" Foreground="#CCC" BorderBrush="#444" FontSize="11" />
                            <Button Grid.Column="2" Content="..." Width="32" Height="28" Margin="6,0,0,0"
                                    Click="BrowseDir_Click" Background="#333" Foreground="#AAA" BorderBrush="#444" Cursor="Hand" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recording -->
                <TextBlock Text="Recording" Style="{StaticResource SectionTitle}" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="ChkRecordAudio" Content="Enable audio recording (microphone)" />
                        <TextBlock Text="When enabled, microphone audio is captured with video. Can also be toggled during recording."
                                   Foreground="#666" FontSize="11" Margin="20,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- History -->
                <TextBlock Text="History" Style="{StaticResource SectionTitle}" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <CheckBox x:Name="ChkSaveHistory" Content="Save screenshot history" />
                        <Grid Margin="0,6,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="History folder" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtHistoryDir" Grid.Column="1" Height="28" Padding="6,4"
                                     Background="#1A1A1E" Foreground="#CCC" BorderBrush="#444" FontSize="11" />
                            <Button Grid.Column="2" Content="..." Width="32" Height="28" Margin="6,0,0,0"
                                    Click="BrowseHistoryDir_Click" Background="#333" Foreground="#AAA" BorderBrush="#444" Cursor="Hand" />
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Max items" Style="{StaticResource Label}" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtMaxHistory" Grid.Column="1" Height="28" Padding="6,4"
                                     Background="#1A1A1E" Foreground="#CCC" BorderBrush="#444" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <Border Grid.Row="1" Background="#222" Padding="20,12" BorderBrush="#333" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Width="90" Height="32" Click="Save_Click"
                        Background="#42A5F5" Foreground="White" BorderBrush="#1E88E5"
                        FontWeight="SemiBold" FontSize="13" Cursor="Hand" />
                <Button Content="Cancel" Width="90" Height="32" Margin="10,0,0,0" Click="Cancel_Click"
                        Background="#333" Foreground="#CCC" BorderBrush="#444" FontSize="13" Cursor="Hand" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
