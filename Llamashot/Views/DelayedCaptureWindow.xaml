<Window x:Class="Llamashot.Views.DelayedCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delayed Capture"
        Width="280" Height="200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Topmost="True">
    <StackPanel Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Delayed Capture" FontSize="18" FontWeight="SemiBold"
                   Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock Text="Delay: " Foreground="#DDD" FontSize="14" VerticalAlignment="Center" />
            <ComboBox x:Name="DelayCombo" Width="80" SelectedIndex="1">
                <ComboBoxItem Content="1 sec" />
                <ComboBoxItem Content="3 sec" />
                <ComboBoxItem Content="5 sec" />
                <ComboBoxItem Content="10 sec" />
            </ComboBox>
        </StackPanel>

        <TextBlock x:Name="CountdownText" Text="" FontSize="48" FontWeight="Bold"
                   Foreground="#2196F3" HorizontalAlignment="Center" Visibility="Collapsed" />

        <Button Content="Start" Width="100" Height="32" Click="Start_Click"
                Background="#2196F3" Foreground="White" BorderBrush="#1976D2"
                FontWeight="SemiBold" HorizontalAlignment="Center" />
    </StackPanel>
</Window>
